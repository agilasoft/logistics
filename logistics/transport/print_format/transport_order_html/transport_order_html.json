 "doctype": "Print Format",
 "font_size": 14,
 "html": "<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <style>\n        * { margin: 0; padding: 0; box-sizing: border-box; }\n        body { font-family: Arial, Helvetica, sans-serif; font-size: 9pt; line-height: 1.4; color: #000; background: white; }\n        .order-container { width: 100%; max-width: 210mm; margin: 0 auto; padding: 0; background: white; display: flex; flex-direction: column; min-height: 100vh; position: relative; }\n        .top-section { flex: 0 0 auto; }\n        .bottom-section { margin-top: auto; flex: 0 0 auto; }\n        .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 3mm; }\n        .logo-placeholder { width: 60mm; height: 30mm; background: #e0e0e0; border: 1px solid #ccc; display: flex; align-items: center; justify-content: center; font-size: 7pt; color: #666; }\n        .company-logo { width: 60mm; height: 30mm; object-fit: contain; }\n        .company-info { flex: 1; text-align: left; padding-left: 3mm; }\n        .company-name { font-size: 12pt; font-weight: bold; margin-bottom: 0; }\n        .company-address { font-size: 7pt; line-height: 1.3; margin-bottom: 0; }\n        .vat-reg { font-size: 7pt; }\n        .main-body { display: flex; justify-content: space-between; margin-bottom: 0; margin-top: 35mm; border: 2px solid #000; padding: 1.5mm; position: relative; }\n        .left-column { flex: 1; padding-right: 5mm; }\n        .right-column { flex: 1; padding-left: 5mm; }\n        .field-row { display: flex; margin-bottom: -1mm; align-items: flex-start; gap: 0.3mm; }\n        .field-label { font-weight: 900; min-width: 28mm; font-size: 8pt; flex-shrink: 0; text-align: right; }\n        .left-column .field-label { text-align: right; min-width: 22mm; }\n        .left-column .field-row { gap: 0.1mm; }\n        .field-value { flex: 1; font-size: 8pt; min-height: 5mm; padding: 0.3mm 0.5mm; background: white; }\n        .customer-info-section { position: absolute; top: -35mm; left: 1.5mm; z-index: 10; max-width: 80mm; }\n        .customer-label { font-weight: bold; font-size: 8pt; margin-top: 5mm; margin-bottom: 1mm; line-height: 1; }\n        .customer-name-box { padding: 0.3mm 0.5mm; font-size: 12pt; font-weight: 900; margin-bottom: 0.1mm; margin-top: -1mm; line-height: 1; background: white; }\n        .customer-address-box { padding: 0.3mm 0.5mm; font-size: 8pt; background: white; width: 100mm; }\n        .qr-section { position: absolute; top: -35mm; right: 1.5mm; text-align: right; z-index: 10; margin-bottom: 30mm; }\n        .qr-code { width: 20mm; height: 20mm; border: 0 solid #000; }\n        .order-title-qr { font-size: 16pt; font-weight: 900; margin-top: 0.11mm; margin-bottom: -1mm; text-align: right; }\n        .reference-number { font-size: 8pt; font-weight: normal; margin-top: 0.1mm; }\n        .packages-table { width: 100%; border-collapse: collapse; margin-top: 0; margin-bottom: 2mm; }\n        .packages-table .table-header { background: #e0e0e0; border: 2px solid #000; }\n        .packages-table .table-header th { padding: 0.3mm 0.5mm; text-align: left; font-size: 7pt; font-weight: bold; color: #000; border-top: 2px solid #000; border-bottom: 2px solid #000; border-left: none; border-right: none; }\n        .packages-table .table-header th:first-child { border-left: 2px solid #000; }\n        .packages-table .table-header th:last-child { border-right: 2px solid #000; }\n        .packages-table .table-header th.num, .packages-table .table-row td.num { text-align: right; }\n        .packages-table .table-row td { padding: 0.3mm 0.5mm; font-size: 7pt; background: white; border: none; border-bottom: 1px solid #ddd; vertical-align: top; }\n        .section-title { font-size: 8pt; font-weight: bold; margin: 2mm 0 1mm 0; }\n        .footer-section { margin-top: 10mm; padding-top: 2mm; padding-bottom: 1mm; border-top: 2px solid #000; font-size: 7pt; background: white; display: block; visibility: visible; page-break-inside: avoid; }\n        @page { size: A4; margin: 12mm 12mm 20mm 12mm; }\n        @media print {\n            body { margin: 0; padding: 0; }\n            .order-container { padding: 0; padding-bottom: 30mm; max-width: 100%; }\n            .footer-section { position: fixed; bottom: 0; left: 0; right: 0; width: 100%; background: white; padding-top: 2mm; padding-bottom: 2mm; padding-left: 12mm; padding-right: 12mm; border-top: 2px solid #000; margin: 0; box-sizing: border-box; z-index: 1000; }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"order-container\">\n        <div class=\"header\">\n            {% set company_doc = frappe.get_doc(\"Company\", doc.company) %}\n            {% if company_doc.company_logo %}\n                <img src=\"{{ company_doc.company_logo }}\" alt=\"Company Logo\" class=\"company-logo\" />\n            {% elif company_doc.logo %}\n                <img src=\"{{ company_doc.logo }}\" alt=\"Company Logo\" class=\"company-logo\" />\n            {% elif company_doc.image %}\n                <img src=\"{{ company_doc.image }}\" alt=\"Company Logo\" class=\"company-logo\" />\n            {% else %}\n                <div class=\"logo-placeholder\">company_logo</div>\n            {% endif %}\n            <div class=\"company-info\">\n                <div class=\"company-name\">{{ company_doc.company_name or doc.company }}</div>\n                <div class=\"company-address\">\n                    {% if company_doc.address %}\n                        {% set company_address = frappe.get_doc(\"Address\", company_doc.address) %}\n                        {{ company_address.address_line1 or '' }}\n                        {% if company_address.address_line2 %} {{ company_address.address_line2 }}{% endif %}\n                        {% if company_address.city %} {{ company_address.city }}{% endif %}\n                        {% if company_address.state %}, {{ company_address.state }}{% endif %}\n                        {% if company_address.country %} {{ company_address.country }}{% endif %}\n                        {% if company_address.pincode %} {{ company_address.pincode }}{% endif %}\n                    {% elif company_doc.address_line1 %}\n                        {{ company_doc.address_line1 }}<br>\n                        {% if company_doc.address_line2 %}{{ company_doc.address_line2 }}<br>{% endif %}\n                        {{ company_doc.city }}{% if company_doc.state %}, {{ company_doc.state }}{% endif %}<br>\n                        {{ company_doc.country }}{% if company_doc.pincode %} {{ company_doc.pincode }}{% endif %}\n                    {% endif %}\n                </div>\n                <div class=\"vat-reg\">\n                    {% if doc.branch %}\n                        {% set branch_doc = frappe.get_doc(\"Branch\", doc.branch) %}\n                        {% if branch_doc.custom_registration_details %}\n                            {{ branch_doc.custom_registration_details }}\n                        {% elif company_doc.tax_id %}\n                            VAT Reg. TIN: {{ company_doc.tax_id }}\n                        {% elif company_doc.tin %}\n                            VAT Reg. TIN: {{ company_doc.tin }}\n                        {% endif %}\n                    {% elif company_doc.tax_id %}\n                        VAT Reg. TIN: {{ company_doc.tax_id }}\n                    {% elif company_doc.tin %}\n                        VAT Reg. TIN: {{ company_doc.tin }}\n                    {% endif %}\n                </div>\n            </div>\n        </div>\n        <div class=\"top-section\">\n        <div class=\"main-body\">\n            <div class=\"customer-info-section\">\n                <div class=\"customer-label\">CUSTOMER</div>\n                <div class=\"customer-name-box\">\n                    {% if doc.customer %}\n                        {% set cust = frappe.get_doc(\"Customer\", doc.customer) %}\n                        {{ cust.customer_name or doc.customer }}\n                    {% endif %}\n                </div>\n                <div class=\"customer-address-box\">\n                    {% if doc.customer %}\n                        {% set cust = frappe.get_doc(\"Customer\", doc.customer) %}\n                        {% if cust.customer_primary_address %}\n                            {% set addr = frappe.get_doc(\"Address\", cust.customer_primary_address) %}\n                            {{ addr.address_line1 or '' }}\n                            {% if addr.address_line2 %} {{ addr.address_line2 }}{% endif %}\n                            {% if addr.city %} {{ addr.city }}{% endif %}\n                            {% if addr.state %}, {{ addr.state }}{% endif %}\n                            {% if addr.country %} {{ addr.country }}{% endif %}\n                            {% if addr.pincode %} {{ addr.pincode }}{% endif %}\n                        {% endif %}\n                    {% endif %}\n                </div>\n            </div>\n            <div class=\"qr-section\">\n                {% set qr_url = 'https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=' + doc.name|urlencode %}\n                <img src=\"{{ qr_url }}\" alt=\"QR Code\" class=\"qr-code\" />\n                <div class=\"order-title-qr\">TRANSPORT ORDER</div>\n                <div class=\"reference-number\">{{ doc.name }}</div>\n            </div>\n            <div class=\"left-column\">\n                <div class=\"field-row\"><div class=\"field-label\">SHIPPER:</div><div class=\"field-value\">{% if doc.shipper %}{% set sh = frappe.get_doc(\"Shipper\", doc.shipper) %}{{ sh.shipper_name or doc.shipper }}{% endif %}</div></div>\n                <div class=\"field-row\"><div class=\"field-label\">CONSIGNEE:</div><div class=\"field-value\">{% if doc.consignee %}{% set cn = frappe.get_doc(\"Consignee\", doc.consignee) %}{{ cn.consignee_name or doc.consignee }}{% endif %}</div></div>\n                <div class=\"field-row\"><div class=\"field-label\">TRANSPORT CO.:</div><div class=\"field-value\">{{ doc.transport_company or '' }}</div></div>\n                <div class=\"field-row\"><div class=\"field-label\">JOB TYPE:</div><div class=\"field-value\">{{ doc.transport_job_type or '' }}</div></div>\n                <div class=\"field-row\"><div class=\"field-label\">FROM / TO:</div><div class=\"field-value\">{{ doc.location_from or '' }} \u2192 {{ doc.location_to or '' }}</div></div>\n                <div class=\"field-row\"><div class=\"field-label\">LOC. TYPE:</div><div class=\"field-value\">{{ doc.location_type or '' }}</div></div>\n                <div class=\"field-row\"><div class=\"field-label\">CONTAINER:</div><div class=\"field-value\">{{ doc.container_no or doc.container or '' }}</div></div>\n            </div>\n            <div class=\"right-column\">\n                <div class=\"field-row\"><div class=\"field-label\">BOOKING DATE:</div><div class=\"field-value\">{% if doc.booking_date %}{{ frappe.utils.formatdate(doc.booking_date, 'MM-dd-yyyy') }}{% endif %}</div></div>\n                <div class=\"field-row\"><div class=\"field-label\">SCHEDULED:</div><div class=\"field-value\">{% if doc.scheduled_date %}{{ frappe.utils.formatdate(doc.scheduled_date, 'MM-dd-yyyy') }}{% endif %}</div></div>\n                <div class=\"field-row\"><div class=\"field-label\">CUST. REF:</div><div class=\"field-value\">{{ doc.customer_ref_no or '' }}</div></div>\n                <div class=\"field-row\"><div class=\"field-label\">MODE / LOAD:</div><div class=\"field-value\">{{ doc.transport_mode or '' }} / {{ doc.load_type or '' }}</div></div>\n                <div class=\"field-row\"><div class=\"field-label\">VEHICLE:</div><div class=\"field-value\">{{ doc.vehicle_type or '' }}</div></div>\n                <div class=\"field-row\"><div class=\"field-label\">REEFER / DG:</div><div class=\"field-value\">{% if doc.reefer %}Reefer {% endif %}{% if doc.contains_dangerous_goods %}DG{% endif %}</div></div>\n                <div class=\"field-row\"><div class=\"field-label\">SALES QUOTE:</div><div class=\"field-value\">{{ doc.sales_quote or '' }}</div></div>\n                <div class=\"field-row\"><div class=\"field-label\">JOB NUMBER:</div><div class=\"field-value\">{{ doc.job_number or '' }}</div></div>\n            </div>\n        </div>\n        <div class=\"section-title\">Packages</div>\n        <table class=\"packages-table\">\n            <thead class=\"table-header\">\n                <tr>\n                    <th>COMMODITY</th>\n                    <th>HS</th>\n                    <th class=\"num\">QTY</th>\n                    <th class=\"num\">PACKS</th>\n                    <th class=\"num\">WEIGHT</th>\n                    <th class=\"num\">VOLUME</th>\n                </tr>\n            </thead>\n            <tbody>\n                {% if doc.packages %}\n                    {% for row in doc.packages %}\n                        <tr class=\"table-row\">\n                            <td>{{ row.commodity or '' }}</td>\n                            <td>{{ row.hs_code or '' }}</td>\n                            <td class=\"num\">{% if row.quantity is not none %}{{ frappe.utils.fmt_money(row.quantity, precision=3) }}{% endif %}</td>\n                            <td class=\"num\">{% if row.no_of_packs is not none %}{{ frappe.utils.fmt_money(row.no_of_packs, precision=3) }}{% endif %}</td>\n                            <td class=\"num\">{% if row.weight is not none %}{{ frappe.utils.fmt_money(row.weight, precision=3) }}{% endif %}</td>\n                            <td class=\"num\">{% if row.volume is not none %}{{ frappe.utils.fmt_money(row.volume, precision=3) }}{% endif %}</td>\n                        </tr>\n                    {% endfor %}\n                {% else %}\n                    <tr class=\"table-row\"><td colspan=\"6\" style=\"text-align:center;padding:4mm;\">No packages</td></tr>\n                {% endif %}\n            </tbody>\n        </table>\n        </div>\n        <div class=\"bottom-section\">\n        <div class=\"footer-section\">\n            <div>Company: {{ doc.company or '' }}</div>\n            {% if doc.branch %}<div>Branch: {{ doc.branch }}</div>{% endif %}\n            {% if doc.cost_center %}<div>Cost Center: {{ doc.cost_center }}</div>{% endif %}\n            {% if doc.profit_center %}<div>Profit Center: {{ doc.profit_center }}</div>{% endif %}\n        </div>\n        </div>\n    </div>\n</body>\n</html>",
